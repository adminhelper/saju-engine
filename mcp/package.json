{
  "name": "saju-engine-mcp",
  "version": "0.1.0",
  "description": "Deterministic Korean Saju (Four Pillars / 사주명리) calculation engine, exposed as a zero-dependency MCP server.",
  "type": "module",
  "main": "lib/saju.mjs",
  "bin": { "saju-engine-mcp": "./server.mjs" },
