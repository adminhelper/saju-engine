  "scripts": {
    "start": "node server.mjs",
    "test": "node ../test/validate.mjs"
  },
  "engines": { "node": ">=18" },
  "keywords": ["saju", "사주", "manse", "만세력", "four-pillars", "bazi", "mcp"],
  "license": "MIT"
}
